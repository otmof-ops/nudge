# ============================================================================
# nudge — .gitattributes
# ============================================================================

# ----------------------------------------------------------------------------
# Auto-detect text files and normalize line endings
# ----------------------------------------------------------------------------
* text=auto

# ----------------------------------------------------------------------------
# Shell scripts
# ----------------------------------------------------------------------------
*.sh text eol=lf
*.bash text eol=lf
*.bats text eol=lf

# ----------------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------------
*.conf text eol=lf
*.desktop text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# ----------------------------------------------------------------------------
# Documentation
# ----------------------------------------------------------------------------
*.md text eol=lf
*.txt text eol=lf

# ----------------------------------------------------------------------------
# systemd units and man pages
# ----------------------------------------------------------------------------
*.service text eol=lf
*.timer text eol=lf
*.1 text eol=lf

# ----------------------------------------------------------------------------
# Makefiles
# ----------------------------------------------------------------------------
Makefile text eol=lf

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
Dockerfile text eol=lf

# ----------------------------------------------------------------------------
# Binary files
# ----------------------------------------------------------------------------
*.pdf binary
*.png binary
*.jpg binary
*.gif binary

# ----------------------------------------------------------------------------
# Linguist overrides (GitHub language stats)
# ----------------------------------------------------------------------------
docs/** linguist-documentation
tests/** linguist-tests
