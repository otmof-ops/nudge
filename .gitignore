# ============================================================================
# nudge — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Operating System
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ----------------------------------------------------------------------------
# Editors and IDEs
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace
.project
.settings/
Session.vim
.netrwhist
tags

# ----------------------------------------------------------------------------
# Environment and Secrets
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.cert
*.p12
credentials.json
secrets.json
service-account.json

# ----------------------------------------------------------------------------
# Build and Release Artifacts
# ----------------------------------------------------------------------------
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*_checksums.txt
dist/
build/
release/

# ----------------------------------------------------------------------------
# Shell / BATS
# ----------------------------------------------------------------------------
*.log
*.bak
*.backup
*.tmp
*.orig
*.rej

# BATS test temp directories
tests/tmp/

# ----------------------------------------------------------------------------
# Test and Coverage Output
# ----------------------------------------------------------------------------
coverage/
*.lcov
htmlcov/
.coverage
.coverage.*
test-results/

# ----------------------------------------------------------------------------
# Logs and Temporary Files
# ----------------------------------------------------------------------------
logs/
*.log.*
.cache/
.tmp/
tmp/
temp/

# ----------------------------------------------------------------------------
# CI — Local Artifacts
# ----------------------------------------------------------------------------
.actrc
